<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/bg_rounded_corner"
    android:layout_marginBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvMealType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="早餐"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/xui_config_color_text_title" />

        <TextView
            android:id="@+id/tvCalories"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="350千卡"
            android:textSize="16sp"
            android:textColor="@color/orange_500" />

    </LinearLayout>

    <TextView
        android:id="@+id/tvFoodItems"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="食物列表"
        android:textSize="16sp"
        android:textColor="@color/xui_config_color_text_content"
        android:layout_marginTop="8dp" />

    <TextView
        android:id="@+id/tvDietTips"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="饮食小贴士"
        android:textSize="14sp"
        android:textColor="@color/xui_config_color_text_gray"
        android:layout_marginTop="4dp" />

</LinearLayout>
