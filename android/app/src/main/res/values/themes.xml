<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 主主题：修改父类为 MaterialComponents 以支持 TextInputLayout -->
    <style name="Theme.WeightLossBetting" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/purple_200</item>
        <item name="android:statusBarColor">@color/purple_700</item>
        
        <!-- XUI 兼容属性 -->
        <item name="XUIThemeStyle">@style/XUITheme.Phone</item>
    </style>

    <style name="XUITheme.Purple" parent="XUITheme.Phone">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryDark">@color/purple_700</item>
        <item name="colorAccent">@color/purple_200</item>
    </style>
    
    <!-- 常用 XUI 主题定义，防止其他库引用 -->
    <style name="XUITheme.Blue" parent="XUITheme.Phone" />
    <style name="XUITheme.Green" parent="XUITheme.Phone" />
    <style name="XUITheme.Red" parent="XUITheme.Phone" />
</resources>
